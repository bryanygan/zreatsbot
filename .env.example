# Discord Bot Configuration
BOT_TOKEN=your_discord_bot_token_here
DISCORD_TOKEN=your_discord_bot_token_here

# Discord IDs
OWNER_ID=123456789012345678
OPENER_CHANNEL_ID=987654321098765432
ROLE_PING_ID=1352022044614590494
ORDER_CHANNEL_MENTION=<#1350935337269985334>

# Database Configuration
# For local development: ./data/pool.db (default)
# For Railway/production: /app/data/pool.db
DB_PATH=./data/pool.db

# Status Monitoring API
# Note: Railway automatically sets PORT - do not set STATUS_API_PORT on Railway
# For local development only:
STATUS_API_PORT=5000
STATUS_API_HOST=0.0.0.0
STATUS_API_KEY=generate_with_python_secrets_token_urlsafe_32

# CORS Configuration
# For local development: http://localhost:4321
# For production: https://yourportfolio.com
CORS_ORIGINS=http://localhost:4321,https://yourportfolio.com

# TTSpotSlideShow bridge (for the /slides command)
# Path to your ttspotslideshow checkout and the Python interpreter that has its
# dependencies installed. Defaults to a sibling ../ttspotslideshow folder and the
# "python" on PATH. The /slides command shells out to that repo's
# bot_ocr_entry.py to run OCR + render slides on the host machine.
TTSPOT_REPO_PATH=../ttspotslideshow
TTSPOT_PYTHON=python

# Instructions for generating STATUS_API_KEY:
# Run: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Copy the output and paste it as the value for STATUS_API_KEY
